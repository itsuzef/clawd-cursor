{
  "app": "gmail",
  "name": "Gmail",
  "domainHints": ["mail.google.com", "gmail.com"],
  "shortcuts": {
    "compose":      "c",
    "send":         "mod+Return",
    "reply":        "r",
    "reply_all":    "a",
    "forward":      "f",
    "archive":      "e",
    "delete":       "#",
    "go_to_inbox":  "g i",
    "go_to_sent":   "g t",
    "search":       "/",
    "next_msg":     "j",
    "prev_msg":     "k",
    "mark_unread":  "U",
    "star":         "s"
  },
  "workflows": {
    "compose_and_send": {
      "name": "compose and send an email",
      "steps": [
        { "type": "pressKey",    "key": "c",              "note": "open compose window" },
        { "type": "wait",        "ms": 800,               "note": "compose window appears; To field is auto-focused" },
        { "type": "typeAtFocus", "field": "recipient",    "note": "then press Tab to advance" },
        { "type": "pressKey",    "key": "Tab" },
        { "type": "typeAtFocus", "field": "subject",      "note": "then Tab to body" },
        { "type": "pressKey",    "key": "Tab" },
        { "type": "typeAtFocus", "field": "body" },
        { "type": "pressKey",    "key": "mod+Return",     "note": "send" },
        { "type": "verify",      "name": "sent_confirmation" }
      ]
    },
    "reply": {
      "name": "reply to the open email",
      "steps": [
        { "type": "pressKey",    "key": "r",          "note": "reply" },
        { "type": "wait",        "ms": 400 },
        { "type": "typeAtFocus", "field": "body" },
        { "type": "pressKey",    "key": "mod+Return", "note": "send" }
      ]
    },
    "search": {
      "name": "search messages",
      "steps": [
        { "type": "pressKey",    "key": "/",          "note": "focus search box" },
        { "type": "typeAtFocus", "field": "query" },
        { "type": "pressKey",    "key": "Return" }
      ]
    },
    "archive": {
      "name": "archive open message",
      "steps": [
        { "type": "pressKey",    "key": "e",          "note": "archive; no confirm" }
      ]
    }
  },
  "tips": [
    "Gmail shortcuts only fire when keyboard shortcuts are enabled in Gmail settings",
    "Do NOT click 'Compose' — press 'c' directly",
    "After pressing 'c', wait ~800ms before typing — compose window needs to mount",
    "Window titles like 'Gmail - username' are NOT clickable elements; click into content"
  ]
}

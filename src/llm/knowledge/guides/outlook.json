{
  "app": "outlook",
  "name": "Outlook",
  "domainHints": ["outlook.live.com", "outlook.office.com"],
  "shortcuts": {
    "compose":     "mod+n",
    "send":        "mod+Return",
    "send_alt":    "alt+s",
    "reply":       "mod+r",
    "reply_all":   "mod+shift+r",
    "forward":     "mod+shift+f",
    "delete":      "Delete",
    "search":      "mod+e",
    "go_to_inbox": "mod+shift+i"
  },
  "workflows": {
    "compose_and_send": {
      "name": "compose and send an email",
      "steps": [
        { "type": "pressKey",    "key": "mod+n",          "note": "new message window" },
        { "type": "wait",        "ms": 1200,             "note": "Outlook's compose is slow to mount, especially in Electron" },
        { "type": "typeAtFocus", "field": "recipient" },
        { "type": "pressKey",    "key": "Tab",           "note": "some Outlook builds put Cc between To and Subject — watch the next focus" },
        { "type": "pressKey",    "key": "Tab",           "note": "advance past Cc/Bcc to Subject" },
        { "type": "typeAtFocus", "field": "subject" },
        { "type": "pressKey",    "key": "Tab" },
        { "type": "typeAtFocus", "field": "body" },
        { "type": "pressKey",    "key": "mod+Return",    "note": "primary send" },
        { "type": "wait",        "ms": 400 },
        { "type": "verify",      "name": "window_closed_or_sent_folder", "note": "if still open, try alt+s as fallback" }
      ]
    },
    "reply": {
      "name": "reply to the open email",
      "steps": [
        { "type": "pressKey",    "key": "mod+r" },
        { "type": "wait",        "ms": 600 },
        { "type": "typeAtFocus", "field": "body" },
        { "type": "pressKey",    "key": "mod+Return" }
      ]
    }
  },
  "tips": [
    "Outlook/Teams/Slack/Discord are Electron/WebView2 apps — ALWAYS wait ~4s after launch before any UIA query",
    "Cmd+Return primary send; Alt+S fallback on Windows, Cmd+Shift+D fallback on Mac Mail",
    "Tab order varies: some builds include Cc/Bcc between To and Subject",
    "The Send button is reliably keyboard-reachable — don't try to click it by name"
  ]
}

{
  "app": "slack",
  "name": "Slack",
  "domainHints": ["app.slack.com", "slack.com"],
  "shortcuts": {
    "quick_switcher":    "mod+k",
    "jump_to":           "mod+k",
    "search":            "mod+g",
    "thread_reply":      "r",
    "next_unread":       "alt+shift+Down",
    "prev_unread":       "alt+shift+Up",
    "mark_read":         "Escape",
    "preferences":       "mod+,",
    "edit_last":         "ArrowUp"
  },
  "workflows": {
    "go_to_inbox": {
      "name": "jump to a channel or DM",
      "steps": [
        { "type": "pressKey",    "key": "mod+k" },
        { "type": "wait",        "ms": 300 },
        { "type": "typeAtFocus", "field": "channel name" },
        { "type": "pressKey",    "key": "Return" }
      ]
    },
    "search": {
      "name": "search messages",
      "steps": [
        { "type": "pressKey",    "key": "mod+g" },
        { "type": "wait",        "ms": 200 },
        { "type": "typeAtFocus", "field": "query" },
        { "type": "pressKey",    "key": "Return" }
      ]
    }
  },
  "tips": [
    "Slack is Electron — wait ~4s after launch before UIA queries",
    "Composing a message is just type + Enter; no mod+n needed",
    "Mod+K is the universal quick switcher — faster than clicking the sidebar"
  ]
}

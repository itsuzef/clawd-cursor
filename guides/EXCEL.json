  "workflows": {
    "create_table": "Click cell A1. Type the first header. Press Tab to move to the next column. Type the next header. Press Enter to go to the next row. Type data in each cell, pressing Tab between columns and Enter between rows. DO NOT use Insert > Table from the ribbon — just type directly into cells.",
    "enter_formula": "Click the target cell. Type = followed by the formula (e.g., =SUM(A1:A10)). Press Enter to confirm.",
    "save_as": "Press Ctrl+Shift+S. Type the filename. Select the save location. Click Save.",
    "format_cells": "Select cells first (click and drag, or Shift+Arrow keys). Then use the Home ribbon tab for formatting (bold, font size, borders).",
    "new_workbook": "Press Ctrl+N for a new blank workbook. If on the start screen, click 'Blank workbook'.",
    "navigate_cells": "Use Arrow keys to move between cells. Ctrl+Arrow jumps to the edge of data. Ctrl+Home goes to A1."
  },
  "layout": {
    "title_bar": "Top of window — shows workbook name",
    "ribbon": "Below title bar — tabs: File, Home, Insert, Page Layout, Formulas, Data, Review, View",

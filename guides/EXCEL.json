    "workspace": "The large grid of cells (A1, B1, C1...) — this is where ALL data entry happens",
    "sheet_tabs": "Bottom of window — Sheet1, Sheet2, etc.",
    "status_bar": "Very bottom — shows Ready, cell count, sum, average"

  "learnedWorkflows": {
    "create_table_with_headers_and_formula": "Press Press Ctrl+Home to go to cell A1. Type text. Press Press Tab to move to B1. Type text. Press Press Tab to move to C1. Type text. Press Press Tab to move to D1. Type text. Press Press Enter to go to next row. Click Click cell A2. Type text. Press Press Enter to confirm formula"
